        /**
         * ฟังก์ชันช่วยสร้างเส้นสนามแม่เหล็กมินิโอบล้อมรอบตัวบาร์แบบไดนามิก
         */
        function buildMiniFieldLines(magnetGroup, len, lineArray) {
            const numLines = 6;
            const rOffset = 0.25;
            const xStart = len / 2;
            const xEnd = -len / 2;

            for (let i = 0; i < numLines; i++) {
                const angle = (i / numLines) * Math.PI * 2;
                const bowRadius = 2.0; // ขอบเขตความโค้งพองออก

                const startPt = new THREE.Vector3(xStart, Math.sin(angle)*rOffset, Math.cos(angle)*rOffset);
                const endPt = new THREE.Vector3(xEnd, Math.sin(angle)*rOffset, Math.cos(angle)*rOffset);

                const mid1 = new THREE.Vector3(xStart * 0.5, Math.sin(angle)*bowRadius, Math.cos(angle)*bowRadius);
                const mid2 = new THREE.Vector3(xEnd * 0.5, Math.sin(angle)*bowRadius, Math.cos(angle)*bowRadius);

                const curve = new THREE.CubicBezierCurve3(startPt, mid1, mid2, endPt);
                const points = curve.getPoints(20);
                const geometry = new THREE.BufferGeometry().setFromPoints(points);
                const lineMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.3 });
                const line = new THREE.Line(geometry, lineMat);
                
                magnetGroup.add(line);
                lineArray.push(line);
            }
        }

        // ==========================================
        // PART 3: ระบบคำนวณแบบจำลองฟิสิกส์ตามเวลาจริง (Faraday & Lenz's Law Physics Engine)
        // ==========================================
        /**
         * ฟังก์ชันหลักคำนวณพลังงานไฟฟ้าและการเปลี่ยนแปลงฟลักซ์แม่เหล็กอ้างอิงวินาที
         * @param {number} time - แสตมป์เวลาการจำลองปัจจุบัน
         * @param {number} delta - ส่วนต่างเวลาระหว่างเฟรม (dt) ในหน่วยมิลลิวินาที
         */
        function updatePhysics(time, delta) {
            // ปรับส่วนต่างเวลามิลลิวินาทีเป็นวินาทีจริง (dt) เพื่อป้องกันความเพี้ยนเฟรมเรตบนหน้าจอความถี่สูง
            let dt = delta / 1000;
            if (dt <= 0 || dt > 0.1) dt = 0.0166; // กำหนดค่าเฉลี่ยเริ่มต้นประมาณ 60 FPS หากมีการพับแท็บจอลง

            // คำนวณความเร็วเชิงกายภาพที่แม่นยำ v = dz/dt (หน่วย: ยูนิตจำลองต่อวินาที)
            let physicalVelocity = (magnetParams.z - magnetParams.prevZ) / dt;
            magnetParams.prevZ = magnetParams.z;

            if(magnetGroup) {
                magnetGroup.position.z = magnetParams.z;
                magnetGroup.position.y = magnetParams.y; // Apply radial offset dynamically
            }

            const z = magnetParams.z;
            const y = magnetParams.y;
            const n = coilTurns;
            
            // 1. คำนวณฟลักซ์แม่เหล็กแบบเรียลไทม์ Phi(z, y) ด้วยการกระจายตัวของเกาส์ (Gaussian Bell Curve)
            // ฟลักซ์แม่เหล็กจะสลายตัวในแนวรัศมีเมื่อห่างจากแกนกลาง (y): radialDecay = exp(-0.08 * y^2)
            const radialDecay = Math.exp(-0.08 * y * y);
            const currentFlux = phiMaxVal * Math.exp(-kField * z * z) * radialDecay;

            // 2. คำนวณแรงเคลื่อนไฟฟ้าตามอนุพันธ์เชิงวิเคราะห์ของกฎฟาราเดย์:
            // EMF = -N * (dPhi/dt) = -N * (dPhi/dz) * (dz/dt)
            // dPhi/dz = -2 * kField * z * Phi(z)
            // เมื่อแทนค่าจะได้สูตรสรุป: EMF = 2 * kField * N * Phi(z, y) * z * v
            const voltageCalibration = 1.5; // ค่าคงที่สเกลเสริมเพื่อการแสดงผลบนหน้ามิเตอร์สวยงามยิ่งขึ้น
            let inducedVoltage = 2 * kField * n * currentFlux * z * physicalVelocity * voltageCalibration;

            // ปล่อยกระแสให้เป็น 0 หากแม่เหล็กเคลื่อนที่ช้าเกินไป ป้องกันปัญหาสายเมาส์ขยับสั่นเบา ๆ
            if(Math.abs(physicalVelocity) < 0.1) inducedVoltage = 0;
            
            currentInducedVoltage = inducedVoltage; 
            updateVoltmeter(inducedVoltage);

            // 3. ปล่อยอัปเดตแผง Flux Monitor บนหน้าต่าง UI ทุก ๆ 150 มิลลิวินาที ป้องกันค่าตัวเลขวิ่งเร็วจนอ่านไม่ออก
            if (time - lastSampleTime > 150) { 
                if (Math.abs(physicalVelocity) > 0.1) {
                    phi1 = phi2;
                    phi2 = currentFlux;
                } else {
                    phi1 = currentFlux;
                    phi2 = currentFlux;
                }
                deltaPhi = phi2 - phi1;
                lastSampleTime = time;

                // เขียนค่าตัวแปรลงวิดเจ็ตแสดงผลบนจอภาพ
                elPhi1.innerText = phi1.toFixed(3) + ' Wb';
                elPhi2.innerText = phi2.toFixed(3) + ' Wb';
                
                const sign = deltaPhi >= 0 ? '+' : '';
                elDeltaPhi.innerText = sign + deltaPhi.toFixed(3) + ' Wb';

                // ปรับแต่งสีและทิศทางการเปลี่ยนแปลงบนจอภาพแบบเรียลไทม์
                if (deltaPhi > 0.001) {
                    elDeltaPhi.className = "font-bold text-emerald-400";
                    elFluxTrendIcon.innerText = "📈";
                    elFluxTrendText.setAttribute('data-i18n', 'fluxIncreasing');
                    elFluxTrendText.innerText = translations[currentLang]['fluxIncreasing'];
                } else if (deltaPhi < -0.001) {
                    elDeltaPhi.className = "font-bold text-rose-400";
                    elFluxTrendIcon.innerText = "📉";
                    elFluxTrendText.setAttribute('data-i18n', 'fluxDecreasing');
                    elFluxTrendText.innerText = translations[currentLang]['fluxDecreasing'];
                } else {
                    elDeltaPhi.className = "font-bold text-slate-400";
                    elFluxTrendIcon.innerText = "🛑";
                    elFluxTrendText.setAttribute('data-i18n', 'fluxStationary');
                    elFluxTrendText.innerText = translations[currentLang]['fluxStationary'];
                }
            }
        }

        /**
         * ฟังก์ชันส่งกระแสแรงดันไปแสดงแถบหน้าปัดเข็มแรงเคลื่อนไฟฟ้าเหนี่ยวนำ (EMF Progress Gauge)
         * @param {number} voltage - ความต่างศักย์ของประจุในหน่วยโวลต์
         */
        function updateVoltmeter(voltage) {
            elVoltage.innerText = voltage.toFixed(1);
            
            // คุมสีให้แสดงทิศทาง: แรงดันไฟฟ้าบวกเป็นสีเขียวมรกต แรงดันไฟฟ้าลบเป็นสีแดงส้มระวังภัย
            if (voltage > 0) {
                elVoltage.style.color = '#10b981'; 
                meterFill.style.backgroundColor = '#10b981';
            } else if (voltage < 0) {
                elVoltage.style.color = '#ef4444'; 
                meterFill.style.backgroundColor = '#ef4444';
            } else {
                elVoltage.style.color = '#1e293b'; 
            }

            // ขีดจำกัดขอบเขตการส่ายของเข็มโวลต์มิเตอร์
            const maxRange = 30; 
            let normalizedV = Math.max(-maxRange, Math.min(maxRange, voltage));
            
            if (normalizedV > 0) {
                const widthPercent = (normalizedV / maxRange) * 50;
                meterFill.style.left = '50%';
                meterFill.style.width = `${widthPercent}%`;
            } else if (normalizedV < 0) {
                const widthPercent = (Math.abs(normalizedV) / maxRange) * 50;
                meterFill.style.left = `${50 - widthPercent}%`;
                meterFill.style.width = `${widthPercent}%`;
            } else {
                meterFill.style.width = '0%';
                meterFill.style.left = '50%';
            }
        }

        // =========================================================================
        // PART 4: ระบบประมวลผลวาดกราฟเส้น 2 มิติ (HTML5 Canvas 2D Graph Engine)
        // ==========================================
        /**
         * ฟังก์ชันหลักในการวาดกราฟสตรีมมิ่งแสดงค่าความต่างศักย์กับแกนเวลาบนแคนวาส
         * @param {number} voltage - แรงดันไฟฟ้าเหนี่ยวนำเหนี่ยวนำในเฟรมปัจจุบัน
         */
        function updateGraph(voltage) {
            voltageHistory.push(voltage);
            if (voltageHistory.length > maxHistoryPoints) {
                voltageHistory.shift(); // คุมขนาดสตรีมมิ่งไม่ให้เปลืองหน่วยความจำ
            }

            const width = graphCanvas.clientWidth;
            const height = graphCanvas.clientHeight;
            
            // ขยายปรับขนาดความละเอียดพิกเซลบนแคนวาสให้คมชัดตลอดเวลา
            if (graphCanvas.width !== width || graphCanvas.height !== height) {
                graphCanvas.width = width;
                graphCanvas.height = height;
            }

            graphCtx.clearRect(0, 0, width, height);

            // 1. เริ่มวาดเส้นตารางระเบียบฟิสิกส์ (Grid Lines Setup)
            graphCtx.strokeStyle = 'rgba(71, 85, 105, 0.15)'; 
            graphCtx.lineWidth = 1;

            const centerY = height / 2;
            
            // วาดจุดกึ่งกลางอ้างอิงแรงดันไฟฟ้าเป็น 0 โวลต์
            graphCtx.beginPath();
            graphCtx.moveTo(0, centerY);
            graphCtx.lineTo(width, centerY);
            graphCtx.stroke();

            // วาดเส้นประเปรียบเทียบระดับความต้านทานแรงดันไฟฟ้าด้านบนและล่าง (+15V, -15V)
            const gridLines = [0.25, 0.75];
            gridLines.forEach(ratio => {
                graphCtx.beginPath();
                graphCtx.setLineDash([5, 5]); 
                graphCtx.moveTo(0, height * ratio);
                graphCtx.lineTo(width, height * ratio);
                graphCtx.stroke();
                graphCtx.setLineDash([]); 
            });

            if (voltageHistory.length < 2) return;

            // 2. เริ่มลากเส้นกราฟความต่างศักย์ (Voltage Path Rendering)
            graphCtx.beginPath();
            graphCtx.lineWidth = 2.5;
            
            const maxVal = 40; // ขีดจำกัดสเกลสูงสุดสำหรับการพล๊อตกราฟแนวตั้ง
            const getX = (index) => (index / (maxHistoryPoints - 1)) * width;
            const getY = (val) => centerY - (val / maxVal) * (height / 2) * 0.95;

            // ไล่โทนสีนีออนสะท้อนแสงสำหรับกราฟฟิสิกส์ล้ำยุคเพื่อให้น่าสนใจ
            const gradient = graphCtx.createLinearGradient(0, 0, width, 0);
            gradient.addColorStop(0, 'rgba(6, 182, 212, 0.2)'); 
            gradient.addColorStop(0.5, '#06b6d4'); 
            gradient.addColorStop(1, '#22d3ee'); 
            graphCtx.strokeStyle = gradient;

            graphCtx.beginPath();
            graphCtx.moveTo(getX(0), getY(voltageHistory[0]));
            for (let i = 1; i < voltageHistory.length; i++) {
                graphCtx.lineTo(getX(i), getY(voltageHistory[i]));
            }
            graphCtx.stroke();

            // 3. วาดและแปะรายละเอียดสเกลตัวอักษรกำกับแกนต่างๆ
            graphCtx.fillStyle = 'rgba(148, 163, 184, 0.7)'; 
            graphCtx.font = '10px Inter, sans-serif';
            graphCtx.fillText('+30V', 10, centerY - (30/maxVal)*(height/2)*0.95 - 4);
            graphCtx.fillText('0V', 10, centerY - 4);
            graphCtx.fillText('-30V', 10, centerY + (30/maxVal)*(height/2)*0.95 + 10);
        }

        /**
         * ลูปควบคุมแอนิเมชันหลักของเอนจินจำลอง 3D (Core Game & Render Loop)
         */
        function animate(time) {
            requestAnimationFrame(animate);

            if (!lastTime) lastTime = time;
            let delta = time - lastTime;
            lastTime = time;

            controls.update(); // ปล่อยประมวลผลทิศหน่วงการมองของ OrbitControls

            // ส่วนของตรรกะควบคุมทิศทางการเคลื่อนไหวสำหรับแต่ละ Preset Scenarios
            if (currentMode === 'p1') { // สถานการณ์: ดันเข้า
                presetTimer += delta * presetSpeed; 
                let progress = Math.min(presetTimer / 3000, 1);
                // ใช้สมการความโค้งสมูท (Ease In Out Cubic Curve) ป้องกันเคลื่อนที่แบบกระตุกตอนเริ่ม
                let ease = progress < 0.5 ? 2 * progress * progress : -1 + (4 - 2 * progress) * progress;
                magnetParams.z = -maxPosLimit + (maxPosLimit * ease);
                sliderMagnet.value = magnetParams.z;
                if (progress >= 1) setPreset('manual'); 

            } else if (currentMode === 'p2') { // สถานการณ์: ดึงออก
                presetTimer += delta * presetSpeed; 
                let progress = Math.min(presetTimer / 1500, 1);
                let ease = progress < 0.5 ? 2 * progress * progress : -1 + (4 - 2 * progress) * progress;
                magnetParams.z = 0 - (maxPosLimit * ease);
                sliderMagnet.value = magnetParams.z;
                if (progress >= 1) setPreset('manual'); 

            } else if (currentMode === 'p3') { // สถานการณ์: วางนิ่งไว้ด้านใน
                presetTimer += delta;
                magnetParams.z = 0; 
                sliderMagnet.value = 0;
                if (presetTimer > 3000) setPreset('manual'); 

            } else if (currentMode === 'p4') { // สถานการณ์: แกว่งต่อเนื่อง (AC Current)
                presetTimer += delta * presetSpeed; 
                magnetParams.z = Math.sin(presetTimer / 600) * maxPosLimit;
                sliderMagnet.value = magnetParams.z;
            }

            // คำนวณฟิสิกส์และระบบวาดกราฟิกแคนวาส
            updatePhysics(time, delta);
            updateGraph(currentInducedVoltage);

            // [NEW] รันเรนเดอร์เฟรมของ Practice 3D (Tab 2) ร่วมในแกนลูปของระบบหลัก
            if (practiceRenderer && practiceScene && practiceCamera) {
                practiceRenderer.render(practiceScene, practiceCamera);
            }

            // เอนจินวิเคราะห์อิเล็กตรอนตามกฎของเลนซ์ (Lenz's Law Particle System)
            if (Math.abs(currentInducedVoltage) > 0.1) {
                // อัตราสปีดการไหลแปรผันตามแรงเคลื่อนไฟฟ้าที่เหนี่ยวนำจริง
                const speed = currentInducedVoltage * 0.00005; 
                currentParticles.forEach(p => {
                    p.mesh.visible = true;
                    p.t += speed; 
                    
                    // หากประจุวิ่งเลยขอบทองแดงด้านซ้ายหรือขวา ให้ย้อนกลับวนซ้ำเป็นลูปไม่มีวันสิ้นสุด
                    if (p.t > 1) p.t = p.t % 1;
                    if (p.t < 0) p.t = 1 + (p.t % 1);

                    const pt = p.path.getPoint(p.t);
                    p.mesh.position.copy(pt);
                });
            } else {
                // ซ่อนอิเล็กตรอนทันทีเมื่อไม่มีการเหนี่ยวนำทางไฟฟ้าเกิดขึ้น (ฟลักซ์คงที่)
                currentParticles.forEach(p => {
                    p.mesh.visible = false;
                });
            }

            renderer.render(scene, camera);
        }

        /**
         * ฟังก์ชันหลักในการคำนวณและปรับเปลี่ยนสมการเศษส่วนในคอลัมน์ Practice อัตโนมัติ (Live Recalculate)
         */
        function recalculateEMF() {
            // 1. คำนวณความต่างศักย์สำหรับ Tab 1 (Direct Delta)
            let nVal = parseInt(inputCalcN.value);
            if (isNaN(nVal)) nVal = 0;
            let phiVal = parseFloat(inputCalcPhi.value);
            if (isNaN(phiVal)) phiVal = 0;
            let tVal = parseFloat(inputCalcT.value);
            if (isNaN(tVal) || tVal <= 0) tVal = 0.01; 

            displayN.innerText = nVal;
            displayPhi.innerText = phiVal.toFixed(3);
            displayT.innerText = tVal.toFixed(2);

            let resultDirect = -1 * nVal * (phiVal / tVal);
            displayResult.innerText = resultDirect.toFixed(2);

            // 2. คำนวณความต่างศักย์สำหรับ Tab 2 (Phi1 -> Phi2 + 3D Mini Graphic)
            let bNVal = parseInt(inputCalcBN.value);
            if (isNaN(bNVal)) bNVal = 0;
            let phi1Val = parseFloat(inputCalcPhi1.value);
            if (isNaN(phi1Val)) phi1Val = 0;
            let phi2Val = parseFloat(inputCalcPhi2.value);
            if (isNaN(phi2Val)) phi2Val = 0;
            let bTVal = parseFloat(inputCalcBT.value);
            if (isNaN(bTVal) || bTVal <= 0) bTVal = 0.01;

            // คํานวณหาผลต่าง Flux: ΔΦ = Φ₂ - Φ₁
            let deltaPhiVal = phi2Val - phi1Val;

            displayBPhi1.innerText = phi1Val.toFixed(3);
            displayBPhi2.innerText = phi2Val.toFixed(3);
            displayBDeltaphi.innerText = (deltaPhiVal >= 0 ? '+' : '') + deltaPhiVal.toFixed(3);

            displayBN.innerText = bNVal;
            displayBNumPhi.innerText = deltaPhiVal.toFixed(3);
            displayBNumT.innerText = bTVal.toFixed(2);

            // ε = -N * (ΔΦ / Δt)
            let resultB = -1 * bNVal * (deltaPhiVal / bTVal);
            displayBResult.innerText = resultB.toFixed(2);

            // [NEW] ขยับและแสดงปริมาณเส้นสนามแม่เหล็กบน Practice 3D ตามสมการฟิสิกส์จริง
            if (practiceMagnet1 && practiceMagnet2) {
                // คำนวณระยะห่าง: ฟลักซ์สูงสุด (0.50 Wb) คือกึ่งกลางพอดี (x=0) ฟลักซ์น้อยย้อนกลับออกไปด้านซ้าย
                let dx1 = 3.5 * (1.0 - Math.min(1.0, phi1Val / 0.50));
                let dx2 = 3.5 * (1.0 - Math.min(1.0, phi2Val / 0.50));

                // เลื่อนตำแหน่งแท่งแม่เหล็ก 1 และ 2 ยึดรอบแกน -4.5 และ 4.5
                practiceMagnet1.position.x = -4.5 - dx1;
                practiceMagnet2.position.x = 4.5 - dx2;

                // อัปเดตความเข้มเส้นแรงแม่เหล็ก (B-Field lines opacity) ให้แปรผันตรงตามความเข้มฟลักซ์
                let op1 = 0.05 + 0.65 * (phi1Val / 0.50);
                let op2 = 0.05 + 0.65 * (phi2Val / 0.50);

                practiceFieldLines1.forEach(line => line.material.opacity = op1);
                practiceFieldLines2.forEach(line => line.material.opacity = op2);
            }
        }

        // =========================================================================
        // PART 5: ส่วนดักจับและส่งผ่านค่าจากหน้าต่าง UI (DOM Event Listeners)
        // =========================================================================
        
        // เมื่อผู้ใช้งานลากปุ่มตรรกะตำแหน่งแม่เหล็กเอง
        sliderMagnet.addEventListener('input', (e) => {
            setPreset('manual'); // หลุดออกจากออโต้เพลย์เข้าสู่ระบบแมนนวลทันที
            magnetParams.z = parseFloat(e.target.value);
        });

        // เมื่อผู้ใช้งานปรับเพิ่มลดจำนวนขดสปริง
        sliderTurns.addEventListener('input', (e) => {
            coilTurns = parseInt(e.target.value);
            textTurns.innerText = coilTurns;
            buildCoil(coilTurns);
        });

        // เมื่อผู้ใช้งานปรับเพิ่มลดสปีดจำลองอัตโนมัติ
        sliderSpeed.addEventListener('input', (e) => {
            presetSpeed = parseFloat(e.target.value);
            textSpeed.innerText = presetSpeed.toFixed(1) + 'x';
        });

        // เมื่อผู้ใช้งานปรับระยะเยื้องแกนของแม่เหล็กออกจากสายไฟ
        sliderOffset.addEventListener('input', (e) => {
            magnetParams.y = parseFloat(e.target.value);
            textOffset.innerText = magnetParams.y.toFixed(1);
            if(magnetGroup) {
                magnetGroup.position.y = magnetParams.y;
            }
        });

        // เมื่อปรับแต่งขีดจำกัดระยะเคลื่อนเดินทางสูงสุดของแม่เหล็ก
        sliderMaxPos.addEventListener('input', (e) => {
            setPreset('manual');
            maxPosLimit = parseFloat(e.target.value);
            textMaxPos.innerText = maxPosLimit.toFixed(1);
            
            // อัปเดตขอบเขตทางกายภาพของสไลเดอร์แม่เหล็กใหม่แบบทันที
            sliderMagnet.min = -maxPosLimit;
            sliderMagnet.max = maxPosLimit;
            
            // ตรึงความปลอดภัยไม่ให้ตำแหน่งปัจจุบันของแม่เหล็กทะลุออกนอกขอบเขตใหม่
            if (magnetParams.z > maxPosLimit) {
                magnetParams.z = maxPosLimit;
            } else if (magnetParams.z < -maxPosLimit) {
                magnetParams.z = -maxPosLimit;
            }
            sliderMagnet.value = magnetParams.z;
        });

        // แปะ Event Listeners สำหรับการคำนวณแบบอินเทอร์แอกทีฟของทั้งสอง Tab
        inputCalcN.addEventListener('input', recalculateEMF);
        inputCalcPhi.addEventListener('input', recalculateEMF);
        inputCalcT.addEventListener('input', recalculateEMF);

        inputCalcBN.addEventListener('input', recalculateEMF);
        inputCalcPhi1.addEventListener('input', recalculateEMF);
        inputCalcPhi2.addEventListener('input', recalculateEMF);
        inputCalcBT.addEventListener('input', recalculateEMF);

        // สั่งให้สคริปต์ 3 มิติและภาษาเริ่มต้นพร้อมทำงานเมื่อระบบเอกสาร HTML พร้อมทำงานสมบูรณ์
        window.onload = function() {
            init3D();
            updateUIText(); 
            recalculateEMF(); // เริ่มคำนวณโจทย์ตัวอย่างครั้งแรกตามดีฟอลต์พารามิเตอร์
        };
    </script>
</body>
