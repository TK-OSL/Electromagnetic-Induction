        /**
         * ฟังก์ชันสร้างโมเดล "ขดลวดสปริง" เส้นเดียว (Helix Single Wire Spring Geometry)
         * @param {number} turns - จำนวนรอบการพันขดลวดตัวนำ (N)
         */
        function buildCoil(turns) {
            // ล้างอ็อบเจกต์ขดลวดเก่าทั้งหมดก่อนสร้างใหม่
            while(coilGroup.children.length > 0){ 
                coilGroup.remove(coilGroup.children[0]); 
            }
            currentParticles = []; // รีเซ็ตกลุ่มประจุไฟฟ้าในสายไฟ

            // สีกึ่งสว่างของทองแดงเคลือบแว็กซ์ที่เห็นได้เด่นชัดในฉากหลังสีทึบ
            const copperMaterial = new THREE.MeshStandardMaterial({ 
                color: 0xffa550, metalness: 0.6, roughness: 0.3 
            });
            
            // ขนาดเส้นผ่าศูนย์กลางประจุเหลืองใหญ่ขึ้นเพื่อไม่ให้จมอยู่ใต้แกนสปริง
            const particleGeo = new THREE.SphereGeometry(0.35, 16, 16);
            const particleMat = new THREE.MeshBasicMaterial({ color: 0xffff00 }); // สีเหลืองเรืองแสงสำหรับอิเล็กตรอน

            // กำหนดพารามิเตอร์โครงสร้างเชิงฟิสิกส์ของเกลียวทองแดง
            const radius = 3.5;
            const wireThickness = 0.15;
            const totalCoilLength = 10; // ความยาวคงที่ในการวางขดสปริง
            const startZ = -totalCoilLength / 2;
            
            // สร้างเส้นทาง Helix Curve เชิงพาราเมตริกสามมิติสำหรับประจุวิ่งและทำท่อทองแดง
            class HelixCurve extends THREE.Curve {
                constructor(scale = 1) {
                    super();
                    this.scale = scale;
                }
                getPoint(t, optionalTarget = new THREE.Vector3()) {
                    const angle = t * Math.PI * 2 * turns;
                    const z = startZ + (t * totalCoilLength);
                    const x = Math.cos(angle) * radius;
                    const y = Math.sin(angle) * radius;
                    return optionalTarget.set(x, y, z).multiplyScalar(this.scale);
                }
            }

            const path = new HelixCurve();
            // กำหนดเซ็กเมนต์ท่อให้ละเอียดยิ่งขึ้นหากขดลวดเยอะขึ้นป้องกันขดลวดเหลี่ยม
            const tubularSegments = Math.max(100, turns * 20); 
            const tubeGeometry = new THREE.TubeGeometry(path, tubularSegments, wireThickness, 8, false);
            const tubeMesh = new THREE.Mesh(tubeGeometry, copperMaterial);
            coilGroup.add(tubeMesh);
            
            // Add current visualization particles along the wire
            const numParticles = Math.min(turns * 2, 40); 
            for(let j=0; j<numParticles; j++) {
                const particle = new THREE.Mesh(particleGeo, particleMat);
                const initialT = j / numParticles; 
                const pt = path.getPoint(initialT);
                particle.position.copy(pt);
                particle.visible = false; // จะแสดงผลเมื่อเกิดแรงเคลื่อนไฟฟ้าเหนี่ยวนำ
                coilGroup.add(particle);
                currentParticles.push({ mesh: particle, t: initialT, path: path });
            }
        }

        /**
         * ฟังก์ชันสร้างแท่งแม่เหล็ก 3 มิติพร้อมลวดลายระบุขั้วเหนือ-ใต้ (Magnetic Bar with N/S Texture)
         */
        function buildMagnet() {
            magnetGroup = new THREE.Group();
            const width = 1.5, height = 1.5, length = 8;
            
            // สร้างพื้นผิวแคนวาส 2 มิติเพื่อวาดอักษรขั้วระบุตำแหน่ง N-S บนแกน
            function createTextTexture(text, bgColor) {
                const canvas = document.createElement('canvas');
                canvas.width = 256;
                canvas.height = 256;
                const context = canvas.getContext('2d');
                context.fillStyle = bgColor;
                context.fillRect(0, 0, 256, 256);
                context.font = 'Bold 160px Inter, Arial, sans-serif';
                context.fillStyle = 'white';
                context.textAlign = 'center';
                context.textBaseline = 'middle';
                context.fillText(text, 128, 138); 
                const texture = new THREE.CanvasTexture(canvas);
                return texture;
            }

            const texNorth = createTextTexture('N', '#e63946'); // ขั้วเหนือสีแดงแรงสูง
            const texSouth = createTextTexture('S', '#1d3557'); // ขั้วใต้สีน้ำน้ำเงินเข้มขรึม
            
            // การจับคู่พื้นผิวกับเหลี่ยมบ็อกซ์แม่เหล็ก
            const matNorthSides = new THREE.MeshStandardMaterial({ color: 0xe63946, metalness: 0.3, roughness: 0.4 });
            const matNorthLabel = new THREE.MeshStandardMaterial({ map: texNorth, metalness: 0.3, roughness: 0.4 });
            const materialsNorth = [matNorthLabel, matNorthLabel, matNorthLabel, matNorthSides, matNorthSides, matNorthSides];

            const matSouthSides = new THREE.MeshStandardMaterial({ color: 0x1d3557, metalness: 0.3, roughness: 0.4 });
            const matSouthLabel = new THREE.MeshStandardMaterial({ map: texSouth, metalness: 0.3, roughness: 0.4 });
            const materialsSouth = [matSouthLabel, matSouthLabel, matSouthLabel, matSouthSides, matSouthSides, matSouthSides];
            
            // โมเดลขั้วเหนือสีแดงอยู่ฝั่งบวก (+Z)
            const geoNorth = new THREE.BoxGeometry(width, height, length/2);
            const meshNorth = new THREE.Mesh(geoNorth, materialsNorth);
            meshNorth.position.z = length/4;
            
            // โมเดลขั้วใต้สีน้ำเงินอยู่ฝั่งลบ (-Z)
            const geoSouth = new THREE.BoxGeometry(width, height, length/2);
            const meshSouth = new THREE.Mesh(geoSouth, materialsSouth);
            meshSouth.position.z = -length/4;

            magnetGroup.add(meshNorth);
            magnetGroup.add(meshSouth);
            
            // วาดและจำลองทิศเส้นแรงแม่เหล็ก (Magnetic Field Lines) ทะลุเข้าออกตามฟิสิกส์จริง
            buildMagneticFieldLines(magnetGroup, length);

            magnetGroup.position.z = magnetParams.z;
            magnetGroup.position.y = magnetParams.y;
            scene.add(magnetGroup);
        }

        /**
         * ฟังก์ชันสร้างและวาดเส้นแรงสนามแม่เหล็กโค้งออกรอบๆ ทิศแท่งแม่เหล็ก (B-Field Lines Generation)
         */
        function buildMagneticFieldLines(parent, magnetLength) {
            const numLines = 8; // จำนวนซีกเส้นแรงแม่เหล็กโค้ง
            const lineMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.25 });
            const arrowMat = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.5 });
            
            const zStart = magnetLength / 2 - 0.5; // จุดพุ่งเริ่มต้นใกล้ขั้วเหนือ
            const zEnd = -magnetLength / 2 + 0.5; // จุดเข้าสู่ขั้วใต้
            const rOffset = 0.8; 

            for(let i=0; i<numLines; i++) {
                const angle = (i / numLines) * Math.PI * 2;
                const bowRadius = 6; // ระยะกว้างระเบิดขอบเขตความโค้งออกด้านข้าง
                
                const startPt = new THREE.Vector3(Math.cos(angle)*rOffset, Math.sin(angle)*rOffset, zStart);
                const endPt = new THREE.Vector3(Math.cos(angle)*rOffset, Math.sin(angle)*rOffset, zEnd);
                
                // กำหนดจุดอ้างอิงส่วนเว้าเบซิเยร์เชิงสามมิติให้สมบูรณ์
                const mid1 = new THREE.Vector3(Math.cos(angle)*bowRadius, Math.sin(angle)*bowRadius, zStart * 1.2);
                const mid2 = new THREE.Vector3(Math.cos(angle)*bowRadius, Math.sin(angle)*bowRadius, zEnd * 1.2);
                
                const curve = new THREE.CubicBezierCurve3(startPt, mid1, mid2, endPt);
                const points = curve.getPoints(40);
                const geometry = new THREE.BufferGeometry().setFromPoints(points);
                const line = new THREE.Line(geometry, lineMat);
                parent.add(line);
                
                const midPoint = curve.getPoint(0.5);
                const tangent = curve.getTangent(0.5).normalize();
                
                const arrowGeo = new THREE.ConeGeometry(0.3, 1, 8);
                const arrow = new THREE.Mesh(arrowGeo, arrowMat);
                arrow.position.copy(midPoint);
                
                const target = midPoint.clone().add(tangent);
                arrow.lookAt(target);
                arrow.rotateX(Math.PI / 2); // ปรับหงายหัวกรวยตามทิศทางความโค้ง tangent
                
                parent.add(arrow);
            }
        }

        // ปรับแต่งและขยายขนาด 3D เอนจินเมื่อผู้ใช้งานย่อหรือขยายหน้าต่างเบราว์เซอร์
